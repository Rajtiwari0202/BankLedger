# Dependency directories (never commit these)
node_modules/
jspm_packages/
web_modules/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul or nyc
coverage
*.lcov

# Next.js build output
.next/
out/

# Nuxt.js build output
.nuxt/
dist/
.output/

# NestJS build output
dist/

# TypeScript cache and build artifacts
*.tsbuildinfo
tsconfig.tsbuildinfo

# Optional npm/Yarn cache directories
.npm
.eslintcache
.stylelintcache
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# Local environment variables (contains secrets, API keys)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# Serverless Webpack directories
.webpack/

# Operating system files
.DS_Store
Thumbs.db
